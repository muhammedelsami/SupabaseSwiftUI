// Secrets.example.xcconfig — committed template.
//
// Setup:
//   1. Copy this file to Secrets.xcconfig (which is git-ignored).
//   2. Fill in your real values from Supabase Dashboard → Project Settings → API.
//
// NOTE: enter the HOST only (no "https://"), because .xcconfig treats // as a
// comment. The app builds the https:// URL in code.

SUPABASE_HOST = YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
